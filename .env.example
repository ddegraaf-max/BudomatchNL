# --- AI-assistent (verplicht voor de chat) ---
ANTHROPIC_API_KEY=sk-ant-...
MODEL=claude-sonnet-4-6

# --- Sessies / accounts (sterk aanbevolen) ---
SESSION_SECRET=verander-dit-in-iets-lang-en-willekeurigs

# --- Opslag ---
DATA_FILE=./data.json

# --- Stripe (betalingen) ---
# Zonder STRIPE_SECRET_KEY valt betalen terug op een demo (lead direct als betaald).
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Basis-URL voor success/cancel-redirects. Leeg = automatisch uit het request.
# Op Railway bijv. https://budomatch-nl.up.railway.app
BASE_URL=

# --- E-mail via Resend (optioneel) ---
RESEND_API_KEY=re_...
MAIL_FROM=Budomatch <onboarding@resend.dev>
MAIL_TO=info@budomatch.pl

# Railway zet PORT automatisch; lokaal standaard 3000
PORT=3000

# --- Database (productie) ---
# PostgreSQL. Op Railway: voeg de PostgreSQL-plugin toe, dan wordt DATABASE_URL automatisch gezet.
# Zonder DATABASE_URL gebruikt de app het JSON-bestand (lib/store.js) — handig voor lokaal.
DATABASE_URL=postgresql://user:pass@host:5432/budomatch
# PGSSL=disable   # alleen zetten als je database geen SSL gebruikt (bijv. lokaal)
